APP_NAME=SQAT Backend Service
APP_ENV=development
API_PREFIX=/api/v1

# Database
# Local PostgreSQL example:
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/sqat_db
# Docker Compose PostgreSQL example:
# DATABASE_URL=postgresql://sqat:sqat_password@localhost:5432/sqat

# JWT auth
# Generate a strong secret:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_long_random_secret_at_least_32_chars
CREDENTIAL_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie config
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# CORS
FRONTEND_ORIGINS=http://localhost:3000

# File uploads and recordings
MAX_UPLOAD_MB=20
UPLOAD_DIR=uploads
RECORDINGS_BASE_PATH=recordings
RECORDER_STORE_PASSWORD_VALUES=false
RECORDER_SCREENSHOT_INDICATOR=true

# Test target
# Phase 3 prefers the project URL uploaded in Phase 1 when available.
BASE_URL=http://localhost:3000
USER_EMAIL=
USER_PASSWORD=
ADMIN_EMAIL=
ADMIN_PASSWORD=
PUBLIC_API_URL=http://localhost:8000

# Rate limiting
RATE_LIMIT_AUTH=300/minute
RATE_LIMIT_API=5000/minute

# HuggingFace embeddings
HF_TOKEN=your_huggingface_token_here
HF_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
HF_MODELS_DIR=models

# Qdrant vector DB
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# LLM provider chain
# Recommended for SQAT Phase 3 Playwright generation:
# - anthropic / Claude Sonnet 4.6 as default
# - groq optional fallback/test provider
LLM_PROVIDER=anthropic
LLM_FALLBACK_CHAIN=anthropic,groq
LLM_MAX_CONCURRENT=4
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BACKOFF_BASE_S=2.0
LLM_RATE_LIMIT_SLEEP=15.0

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=2048

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# Scenario generation controls
SCENARIO_AGENT_BATCH_CHARS=4500
SCENARIO_AGENT_BATCH_SIZE=4
SCENARIO_AGENT_MAX_SCENARIOS_PER_BATCH=5
SCENARIO_AGENT_BATCH_DELAY_SECONDS=1.0
SCENARIO_DEDUP_MAX_CHARS=8000

# Jira integration
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_LEAD_ACCOUNT_ID=712020:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Phase 3 queue and execution
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=phase3_test_jobs
RABBITMQ_DLX=phase3.dlx
RABBITMQ_DLQ=phase3_test_jobs.dead
PHASE3_MAX_ATTEMPTS=3
PHASE3_AGENT_RETRY_ATTEMPTS=3

# Demo/local setting: 1 headed worker is easier to watch.
# Production/CI setting: headless with higher worker count.
CHROMIUM_WORKERS=3
PLAYWRIGHT_HEADED=false
PLAYWRIGHT_SLOW_MO_MS=3000
PLAYWRIGHT_TEST_TIMEOUT_MS=30000
WORKER_SUBPROCESS_TIMEOUT_MS=600000
REQUEUE_DELAY_MS=15000
VISION_FALLBACK=false

# Worker mode
# true  = workers run in-process with the API server
# false = run external workers with: python -m app.services.phase3_worker
PHASE3_EMBEDDED_WORKERS=true
PHASE3_EXTERNAL_RUN_TIMEOUT_S=3600

# Runtime state and generated scripts
STATE_JSON_PATH=state.json
GENERATED_SCRIPTS_DIR=tests/generated

# Generic Phase 3 generated test data. Override for locale-specific apps.
PHASE3_TEST_DATA_NAME=Test User
PHASE3_TEST_DATA_POSTAL_CODE=12345
PHASE3_TEST_DATA_PHONE=9000000000
PHASE3_TEST_DATA_SEARCH=test
PHASE3_TEST_DATA_EMAIL=qa.user@example.test

# A4 strictness
# true surfaces missing Phase-1 snapshots as HUMAN_REVIEW instead of silently
# producing scripts from empty DOM context.
A4_STRICT_SNAPSHOT=false

# Cleanup
SCRIPT_RETENTION_HOURS=72
SCRIPT_CLEANUP_ENABLED=true
AUTH_STATE_RETENTION_HOURS=24
AUTH_SETUP_TIMEOUT_S=90
AUTH_STATE_CLEANUP_INTERVAL_MINUTES=60
AUTH_STATE_CLEANUP_ENABLED=true
