APP_NAME=SQAT Backend Service
APP_ENV=development
API_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────────────────────
# Replace YOUR_PASSWORD with your PostgreSQL password
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/sqat_db

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Cookie Config ─────────────────────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGINS=http://localhost:3000

# ── File Uploads ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=20
UPLOAD_DIR=uploads

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=300/minute
RATE_LIMIT_API=5000/minute

# ── HuggingFace (Sentence Transformers / Embeddings) ─────────────────────────
# Required for RAG / semantic search features.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
# Optional model repo id (default: sentence-transformers/all-MiniLM-L6-v2)
HF_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# Optional local directory for cached/downloaded models (relative to server/)
HF_MODELS_DIR=models

# ── Qdrant Vector DB ──────────────────────────────────────────────────────────
# Sign up at: https://cloud.qdrant.io
# Create a cluster → copy the URL and API key from the cluster dashboard.
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Groq LLM ──────────────────────────────────────────-------────────────────
# Get your API key from: https://console.groq.com/keys
# You can provide multiple keys for fallback/rotation with commas:
# GROQ_API_KEY=gsk_key_one,gsk_key_two,gsk_key_three
GROQ_API_KEY=your_groq_api_key_here

# Default model used by the LangGraph scenario-generation agents.
# Recommended production text models currently listed by Groq:
#   llama-3.3-70b-versatile  - best quality default for QA scenario generation
#   llama-3.1-8b-instant     - faster / cheaper, lower reasoning depth
#   openai/gpt-oss-120b      - strong open-weight reasoning model
#   openai/gpt-oss-20b       - faster / cheaper GPT-OSS option
#
# Groq also exposes production systems:
#   groq/compound
#   groq/compound-mini
#
# Check the latest available model IDs with:
#   curl -H "Authorization: Bearer $GROQ_API_KEY" https://api.groq.com/openai/v1/models
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# Keep scenario-generation prompts small enough for Groq on-demand TPM limits.
# Lower these if you still see 413/rate_limit_exceeded errors.
SCENARIO_AGENT_BATCH_CHARS=4500
SCENARIO_AGENT_BATCH_SIZE=4
SCENARIO_AGENT_MAX_SCENARIOS_PER_BATCH=5
SCENARIO_AGENT_BATCH_DELAY_SECONDS=1.0
SCENARIO_DEDUP_MAX_CHARS=8000

# ── Jira Integration ──────────────────────────────────────────────────────────
# All four fields are required for the "Connect to Jira" and "Raise Ticket" features.
#
# JIRA_BASE_URL   → Your Atlassian workspace, e.g. https://yourcompany.atlassian.net
# JIRA_EMAIL      → Email you log in to Jira with
# JIRA_API_TOKEN  → https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_LEAD_ACCOUNT_ID → Your Jira account ID (not email).
#                        Find it at: https://yourcompany.atlassian.net/rest/api/3/myself
#                        Look for the "accountId" field in the JSON response.
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_LEAD_ACCOUNT_ID=712020:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
