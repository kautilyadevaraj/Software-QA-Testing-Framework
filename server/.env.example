APP_NAME=SQAT Backend Service
APP_ENV=development
API_PREFIX=/api/v1

DATABASE_URL=postgresql://postgres:{password}@localhost:5432/sqat_db

JWT_SECRET_KEY=at_least_24_characters_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

FRONTEND_ORIGINS=http://localhost:3000

MAX_UPLOAD_MB=20
UPLOAD_DIR=uploads

# Keep limits high in development for heavy testing traffic.
RATE_LIMIT_AUTH=300/minute
RATE_LIMIT_API=5000/minute

# --- Knowledge Base / Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=sqat_chunks

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Chunking Parameters ---
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# --- Extracted text output ---
EXTRACTED_TEXT_DIR=extracted