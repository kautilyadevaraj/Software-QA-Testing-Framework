# Normalize text files to LF across Windows/macOS/Linux.
* text=auto eol=lf

# Binary files should not receive line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.xlsx binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Windows scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
