# Normalize all text files to LF on checkout (consistent across Windows/macOS/Linux)
* text=auto eol=lf

# Explicitly binary — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.xlsx binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Windows batch/powershell — keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
