# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Node / Next.js ─────────────────────────────────────────────────────────
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
**/.next/
**/out/

# Production build
**/build/
**/dist/
**/.cache/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ── Python / FastAPI ────────────────────────────────────────────────────────
**/.venv/
**/venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# uv lock — uncomment to ignore if you don't want to pin deps in CI
# uv.lock

# Pytest / coverage
.pytest_cache/
**/.pytest_cache/
.coverage
**/htmlcov/

# Mypy
.mypy_cache/
**/.mypy_cache/

# ── Environment & Secrets ───────────────────────────────────────────────────
# All .env files are ignored EXCEPT .env.example files
.env*
!**/.env.example

# ── Uploaded user files ─────────────────────────────────────────────────────
# Never commit credentials CSVs, PDFs, swagger docs uploaded by users
uploads/
**/uploads/

# ── Local ML model cache ─────────────────────────────────────────────────────
server/models/

# ── Testing ─────────────────────────────────────────────────────────────────
**/coverage/

# ── Logs ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# ── OS / Editor junk ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/
*.swp
*.swo
*.tmp
c.py

# ── Prisma (legacy — not used but kept for safety) ──────────────────────────
/app/generated/prisma
prisma/migrations
*.db
*.db-journal

# ── Deployment ──────────────────────────────────────────────────────────────
.vercel
docs
