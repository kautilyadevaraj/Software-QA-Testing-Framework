# ── Node / Next.js ─────────────────────────────────────────────────────────
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
**/.next/
**/out/

# Production build
**/build/
**/dist/
**/.cache/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ── Python / FastAPI ────────────────────────────────────────────────────────
**/.venv/
**/venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# uv lock — keep pinned deps (comment out if you don't want to pin in CI)
# uv.lock

# Pytest / coverage
.pytest_cache/
**/.pytest_cache/
.coverage
**/htmlcov/

# Mypy
.mypy_cache/
**/.mypy_cache/

# ── Environment & Secrets ───────────────────────────────────────────────────
# All .env files are gitignored EXCEPT .env.example templates
.env*
!**/.env.example

# ── Uploaded user files ─────────────────────────────────────────────────────
# Never commit user PDFs, Swagger docs, credentials CSVs, etc.
uploads/
**/uploads/

# ── Generated Playwright scripts & test output ──────────────────────────────
server/tests/generated/
server/tests/tests/              # nested generated trace output folder
server/test-results/
server/test_docs/
server/state.json
*.spec.ts.tmp
**/traces/
**/.last-run.json
**/error-context.md

# ── Playwright auth state (contains credentials — never commit) ──────────────
**/auth.json

# ── Playwright (server-side Node install) ───────────────────────────────────
server/node_modules/
server/package-lock.json

# ── JSON / text report dumps (dev artifacts) ────────────────────────────────
server/report.json
server/report_utf8.json
server/test_output.txt

# ── Local ML model cache ─────────────────────────────────────────────────────
server/models/

# ── Logs ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# ── OS / Editor junk ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/
*.swp
*.swo
*.tmp

# ── Prisma (legacy) ──────────────────────────────────────────────────────────
/app/generated/prisma
prisma/migrations
*.db
*.db-journal

# ── Deployment ──────────────────────────────────────────────────────────────
.vercel
