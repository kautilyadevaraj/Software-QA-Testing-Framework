    Human -- "2. Navigates App manually" --> Recorder
    ReactUI <-- REST --> API2
    API2 -- Triggers --> LG
    LG --> A1 & A2 & A3
    A1 -. MCP: fetch_vector_context .-> API2
    A3 -. MCP: read_api_specifications .-> API2
    A2 -. MCP: commit_test_scenario .-> API2
    Recorder -- POST Discovered DOM/Network --> API2
    API2 <-- SQL Queries --> DB2
    API2 <-- Vector Retrieval --> Qdrant2
    UI --> EP1
    UI --> EP2
    UI --> EP3
    EP1 --> ORCH
    INPUTA --> ORCH
    INPUTB --> ORCH
    ORCH --> PLAN
    PLAN --> CTX
    CTX --> SGEN
    PLAN --> DBTOOL
    CTX --> DOM
    SGEN --> SCR
    SCR --> QUEUE
    DBTOOL --> QUEUE
    QUEUE --> RMQ
    RMQ --> CHR
    CHR --> STATEJSON
    STATEJSON --> A5
    A5 --> PASS
    A5 --> SERR
    A5 --> AERR
    SERR --> RETRY
    RETRY --> RMQ
    AERR -. Human Review .-> RQP
    RETRY -. Human Review .-> RQP
    RQP --> ACTION1
    RQP --> ACTION2
    ACTION1 --> EP6
    ACTION2 --> EP5
    PASS --> TC
    PASS --> TR
    PASS --> NL
    RETRY --> RH
    AERR --> RQ
    STORAGE_LAYER --> P4
    Qdrant1 -- Vectors available for retrieval --> Qdrant2
    DB1 -- Metadata and State passed to Phase 2 --> DB2
    A2 -- Committed Test Scenarios --> INPUTA
    Recorder -- Discovered DOM Snapshots --> INPUTB
